{
  "name": "bctranslate",
  "version": "1.0.5",
  "description": "CLI to transform source files into i18n-ready code with automatic translation via argostranslate",
  "type": "module",
  "bin": {
    "bctranslate": "./bin/bctranslate.js"
  },
  "main": "src/index.js",
  "files": [
